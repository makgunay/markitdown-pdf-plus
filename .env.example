# Copy to `.env` (gitignored) and fill in real values. Never commit `.env`.
#
# The plugin itself takes no secrets directly: you pass an OpenAI-compatible
# `llm_client` to MarkItDown. These vars are read by the underlying `openai`
# client when you construct it, and by the eval/integration helpers.

# OpenAI (cloud VLM path). Required only when using an OpenAI model.
OPENAI_API_KEY=sk-your-key-here

# Local Ollama / LM Studio (OpenAI-compatible) endpoint.
# For Ollama the key is a non-empty placeholder; the base URL is what matters.
OPENAI_BASE_URL=http://localhost:11434/v1

# Opt in to the live-VLM eval/integration tests (see tests/eval/run_eval.py).
# PDFPLUS_OLLAMA=1
# RUN_VLM_INTEGRATION=1
